APP_NAME="SNMP Bridge Provisioning System"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://10.10.5.56/snmp-bridge/public
APP_TIMEZONE=Europe/Madrid

INTERNAL_DB_HOST=127.0.0.1
INTERNAL_DB_PORT=3306
INTERNAL_DB_DATABASE=snmp_bridge
INTERNAL_DB_USERNAME=root
INTERNAL_DB_PASSWORD=Pandor4!
INTERNAL_DB_CHARSET=utf8mb4

PANDORA_DB_HOST=127.0.0.1
PANDORA_DB_PORT=3306
PANDORA_DB_DATABASE=pandora
PANDORA_DB_USERNAME=root
PANDORA_DB_PASSWORD=Pandor4!
PANDORA_DB_CHARSET=utf8mb4

SNMP_VERSION=2c
SNMP_COMMUNITY=public
SNMP_PORT=161
SNMP_TIMEOUT_USEC=1000000
SNMP_RETRIES=1
SNMP_MAX_OIDS=10
SNMP_QUICK_PRINT=true
SNMP_VALUE_PARSING=plain

PANDORA_MODULE_INTERVAL=300
PANDORA_MODULE_TIMEOUT=5
PANDORA_MODULE_RETRIES=1

LOG_CHANNEL=file
LOG_LEVEL=info
LOG_PATH=storage/logs/app.log
