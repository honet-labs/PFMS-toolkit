                            </a>
                        </td>
                        <td><?= htmlspecialchars($ip) ?></td>
                        <td><code class="serial-text"><?= htmlspecialchars(str_replace('"', '', $serial)) ?></code></td>
                        <td class="text-center" title="<?= htmlspecialchars($brand_text) ?>">
                            <span style="display:none;"><?= htmlspecialchars($brand_text) ?></span>
                            <?php if (!empty($final_icon_path)): ?>
                                <img src="<?= htmlspecialchars($final_icon_path) ?>" class="os-icon" onerror="this.style.display='none'" alt="Brand Icon">
