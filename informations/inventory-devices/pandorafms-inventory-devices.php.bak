<?php
/**
 * PANDORA FMS - CUSTOM INVENTORY DEVICE DASHBOARD
 * Version: 2.4 (Clean Layout + Fixed ColVis Checkbox UI)
 */

$DEFAULT_TZ = "Asia/Jakarta";
date_default_timezone_set($DEFAULT_TZ);
error_reporting(E_ALL & ~E_NOTICE & ~E_WARNING);

// =====================================================================
// 1. DYNAMIC BREADCRUMB LOGIC
// =====================================================================
$raw_path = parse_url($_SERVER['REQUEST_URI'], PHP_URL_PATH); 
$dir_only = dirname($raw_path); 
$clean_path = trim($dir_only, '/'); 

$path_array = explode('/', $clean_path);
$formatted_array = array_map(function($p) {
    return ucwords(str_replace(['_', '-'], ' ', $p));
}, $path_array);
$dynamic_breadcrumb = implode(' / ', $formatted_array);

// =====================================================================
// 2. FAST CONFIG LOADING
// =====================================================================
$config_paths = ['/var/www/html/pandora_console/include/config.php', '../../include/config.php', '../include/config.php'];
$config_loaded = false;
foreach ($config_paths as $path) { 
    if (file_exists($path)) { 
        require_once($path); 
        $config_loaded = true; 
        break; 
    } 
}

// =====================================================================
// 3. DATABASE CONNECTION & OPTIMIZED QUERY
// =====================================================================
$inventoryData = [];
$serialsMap = [];

try {
    $dsn = "mysql:host=" . $config["dbhost"] . ";dbname=" . $config["dbname"] . ";charset=utf8";
    $options = [
        PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
        PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        PDO::ATTR_EMULATE_PREPARES   => false,
        PDO::ATTR_PERSISTENT         => false // Non-persistent untuk menghindari pool exhaustion
    ];
    $pdo = new PDO($dsn, $config["dbuser"], $config["dbpass"], $options);

    // OPTIMASI 1: Ambil Serial Number secara bulk
    $serialSql = "SELECT tm.id_agente, e.datos
                  FROM tagente_modulo tm
                  INNER JOIN tagente_estado e ON tm.id_agente_modulo = e.id_agente_modulo
                  WHERE tm.nombre IN (
                      'SNMPv2-SMI::mib-2.47.1.1.1.1.11.1',
                      'SNMPv2-SMI::mib-2.47.1.1.1.1.11.67108867',
                      'SNMPv2-SMI::enterprises.3902.1082.500.10.2.3.3.1.18.285278465.1'
                  )";
    $serialStmt = $pdo->query($serialSql);
    while ($row = $serialStmt->fetch()) {
        if (!isset($serialsMap[$row['id_agente']])) {
            $serialsMap[$row['id_agente']] = $row['datos']; 
        }
    }

    // OPTIMASI 2: Query Utama bersih dari subquery string-matching
    $sql = "SELECT
                a.id_agente AS agent_id,
                a.alias AS agent_alias,
                a.direccion AS ip_address,
                g.nombre AS group_agent,
                os.name AS os_name,
                os.icon_name AS brand_icon,
                a.intervalo AS agent_interval,
                a.ultimo_contacto AS last_contact,
                (SELECT timestamp FROM tagente_estado WHERE id_agente = a.id_agente ORDER BY timestamp DESC LIMIT 1) AS last_status_change
            FROM tagente a
            LEFT JOIN tgrupo g ON a.id_grupo = g.id_grupo
            LEFT JOIN tconfig_os os ON a.id_os = os.id_os
            WHERE a.disabled = 0
            ORDER BY a.alias ASC";
    
    $stmt = $pdo->query($sql);
    $inventoryData = $stmt->fetchAll();
    
    $pdo = null;

} catch(PDOException $e) {
    die("<div style='font-family:Lato, sans-serif; font-weight:700; padding:20px; text-align:center; color:#e74c3c;'>Database Connection Failed: " . $e->getMessage() . "</div>");
}

// =====================================================================
// 4. HELPERS FORMATTING
// =====================================================================
function cleanPandoraText($text) {
    if ($text === null || $text === '') return 'Unknown';
    $text = html_entity_decode($text, ENT_QUOTES | ENT_HTML5, 'UTF-8');
    return str_replace('&#x20;', ' ', $text);
}

function formatInterval($seconds) {
    $seconds = (int)$seconds;
    if ($seconds <= 0) return 'N/A';
    if ($seconds >= 86400) return ($seconds / 86400) . " days";
    if ($seconds >= 3600) return ($seconds / 3600) . " hours";
    if ($seconds >= 60) return ($seconds / 60) . " minutes";
    return $seconds . " seconds";
}

function timeAgo($datetime) {
    if (empty($datetime) || $datetime == '0000-00-00 00:00:00') return 'N/A';
    $time = strtotime($datetime);
    $diff = time() - $time;
    if ($diff < 0) $diff = 0;
    if ($diff < 10) return "Now";

    $days = floor($diff / 86400);
    $hours = floor(($diff % 86400) / 3600);
    $minutes = floor(($diff % 3600) / 60);

    if ($days > 0) return $days . " days" . ($hours > 0 ? " " . $hours . " hours" : "");
    if ($hours > 0) return $hours . " hours" . ($minutes > 0 ? " " . $minutes . " minutes" : "");
    if ($minutes > 0) return $minutes . " minutes";
    return $diff . " seconds";
}
?>

