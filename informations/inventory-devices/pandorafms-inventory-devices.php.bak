<script>
$(document).ready(function() {
    var exportFormatConfig = {
        body: function ( data, row, column, node ) {
            return $('<div>').html(data).text().trim();
        }
    };

    var table = $('#inventoryTable').DataTable({
        "lengthMenu": [[15, 30, 50, 100, -1], [15, 30, 50, 100, "All"]],
        "pageLength": 30,
        // DOM diubah agar Filter (f) dan Buttons (B) berada di dalam top-controls-wrapper
        "dom": "<'top-controls-wrapper'Bf>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'bottom-controls-wrapper'<'spacer-left'i><'center-pagination'p><'right-length'l>>",
        "language": {
            "lengthMenu": "Show _MENU_ entries",
            "search": "", 
            "searchPlaceholder": "Search table data..."
        },
        "buttons": [
            {
                extend: 'csvHtml5',
                text: '<span class="material-symbols-outlined" style="font-size:16px!important;">download</span> CSV',
                className: 'btn-secondary-custom',
                fieldSeparator: '|',
                title: 'Inventory_PandoraFMS_' + new Date().toISOString().slice(0,10),
                exportOptions: { columns: ':visible', format: exportFormatConfig }
            },
            {
                extend: 'csvHtml5',
                text: '<span class="material-symbols-outlined" style="font-size:16px!important;">description</span> TXT',
                className: 'btn-secondary-custom',
                fieldSeparator: '|',
                extension: '.txt',
                title: 'Inventory_PandoraFMS_' + new Date().toISOString().slice(0,10),
                quoteChar: '',
                exportOptions: { columns: ':visible', format: exportFormatConfig }
            },
            {
                extend: 'pdfHtml5',
                text: '<span class="material-symbols-outlined" style="font-size:16px!important;">picture_as_pdf</span> PDF',
                className: 'btn-secondary-custom',
                orientation: 'landscape',
                pageSize: 'A4',
                exportOptions: { columns: ':visible', format: exportFormatConfig },
                customize: function (doc) {
                    doc.styles.title.fontSize = 14;
                    doc.styles.title.alignment = 'center';
                    doc.styles.title.margin = [0, 0, 0, 15];
                    doc.styles.tableHeader.fillColor = '#f8f9fa';
                    doc.styles.tableHeader.color = '#000000';
                    doc.styles.tableHeader.alignment = 'center';
                    doc.defaultStyle.color = '#000000';
                    doc.defaultStyle.fontSize = 8;
                    doc.content[1].table.widths = ['5%', '15%', '10%', '15%', '8%', '7%', '10%', '10%', '10%', '10%'];
                }
            },
            {
                extend: 'colvis',
                text: '<span class="material-symbols-outlined" style="font-size:16px!important;">view_column</span> Columns',
                className: 'btn-secondary-custom'
            }
        ]
    });

    // Mengaktifkan fitur Global Search dari Top Navbar
    $('#globalSearch').on('keyup', function () {
        table.search(this.value).draw();
    });
});
</script>
</body>
</html>
