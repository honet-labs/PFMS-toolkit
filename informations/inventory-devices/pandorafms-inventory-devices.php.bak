                    <?php foreach ($inventoryData as $row): 
                        $serial = isset($serialsMap[$row['agent_id']]) ? $serialsMap[$row['agent_id']] : 'N/A';
                        if (strpos($serial, 'No Such Instance') !== false) $serial = 'N/A';
                        if (empty($serial)) $serial = 'N/A';

                        $agent_alias = cleanPandoraText($row['agent_alias']);
                        $group_agent = cleanPandoraText($row['group_agent']);
                        $os = cleanPandoraText($row['os_name']);
                        $ip = !empty($row['ip_address']) ? $row['ip_address'] : 'N/A';

                        $icon_file = $row['brand_icon'];
                        $brand_text = 'Unknown';
                        $final_icon_path = "";

                        if (!empty($icon_file)) {
                            $final_icon_path = "/pandora_console/images/os_icons/" . $icon_file;
                            $brand_text = ucfirst(pathinfo($icon_file, PATHINFO_FILENAME));
                            if (substr(strtolower($brand_text), 0, 3) === 'so_') {
                                $brand_text = ucfirst(substr($brand_text, 3));
                            }
                        }

                        $search_key = strtolower($brand_text . " " . $os);
                        if (strpos($search_key, 'cisco') !== false) {
                            $final_icon_path = "/pandora_console/images/cisco@os.svg";
                            $brand_text = "Cisco";
                        } elseif (strpos($search_key, 'windows') !== false) {
                            $final_icon_path = "/pandora_console/images/windows@os.svg";
                            $brand_text = "Windows";
                        } elseif (strpos($search_key, 'linux') !== false) {
                            $final_icon_path = "/pandora_console/images/linux@os.svg";
                            $brand_text = "Linux";
                        }

                        $interval_val = formatInterval($row['agent_interval']);
                        $last_contact_val = timeAgo($row['last_contact']);
                        $status_change_raw = !empty($row['last_status_change']) ? $row['last_status_change'] : $row['last_contact'];
                        $last_status_change_val = timeAgo($status_change_raw);
                    ?>
                    <tr>
                        <td class="text-center" style="color:#7f8c8d !important;"><?= $row['agent_id'] ?></td>
